# Telegram bot token from @BotFather
BOT_TOKEN=PASTE_YOUR_BOTFATHER_TOKEN_HERE

DB_HOST=localhost
DB_PORT=5432
DB_NAME=books_store
DB_USER=books
DB_PASSWORD=DB_PASSWORD

# Docker only: host-side port for reaching the DB (bound to 127.0.0.1)
DB_EXTERNAL_PORT=5433

# How many nearest stores to show the user
NEAREST_LIMIT=5

# Comma-separated Telegram chat IDs allowed into /admin
ADMIN_IDS=ADMIN_ID

# Public Google Sheet to import real stores from
SHEET_ID=SHEET_ID
SHEET_GID=0

# --- Webhook mode (production) ---
# Set WEBHOOK_URL to your domain to run via webhook instead of long polling.
# Leave it EMPTY for local development (uses polling). Caddy handles TLS.
WEBHOOK_URL=https://falaqnashrcloud.uz
# Optional: a secret token Telegram echoes back (auto-derived if left empty).
WEBHOOK_SECRET=
